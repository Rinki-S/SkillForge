# @cloudflare/kumo declares zod@^4 as a *peerOptional* dependency; this app
# uses zod@3 for its own form schemas and only imports kumo's UI primitives
# (which don't need zod). Optional peers are safe to skip, so disable npm's
# strict peer resolution. This mirrors the local install environment and keeps
# `npm ci` working inside Docker.
legacy-peer-deps=true
